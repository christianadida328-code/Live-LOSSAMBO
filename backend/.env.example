# Backend Flask
SECRET_KEY=change_me
JWT_SECRET_KEY=change_me_too
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# CORS (séparés par virgule)
CORS_ORIGINS=http://localhost:5173

# Mode DB:
# - par défaut: PostgreSQL si DATABASE_URL est défini et joignable
# - fallback automatique sur SQLite si Postgres indisponible
USE_SQLITE=false
FORCE_SQLITE=false

# PostgreSQL (optionnel)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/live_lossambo

# SQLite (utilisé en dev / fallback)
SQLITE_DATABASE_URL=sqlite:///dev.db

# Bootstrap admin (optionnel)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_password
# ADMIN_DISPLAY_NAME=Admin

